{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "java: build",
            "type": "shell",
            "command": "javac",
            "args": [
                "-d",
                "bin",
                "${fileDirname}/**/*.java"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$javac"],
            "group": "build"
        },
        {
            "label": "java: clean",
            "type": "shell",
            "command": "Remove-Item",
            "args": [
                "-Path",
                "bin",
                "-Recurse",
                "-Force",
                "-ErrorAction",
                "SilentlyContinue"
            ],
            "options": {
                "shell": {
                    "executable": "powershell.exe",
                    "args": ["-Command"]
                },
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        }
    ]
}
